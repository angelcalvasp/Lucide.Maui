<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:icons="clr-namespace:Lucide.Maui;assembly=Lucide.Maui"
             x:Class="Lucide.Maui.Components.LucideIcon">
    <Image x:Name="FontImage">
        <Image.Source>
            <FontImageSource x:Name="ImageSource" 
                             FontFamily="{x:Static icons:LucideIconsConfig.FontFamily}"/>
        </Image.Source>
    </Image>
    
</ContentView>